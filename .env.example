# nexus-commit environment variables example
# Copy this to .env and adjust values as needed.

# Nexus server base URL (optional, for local index search)
NEXUS_API_URL=http://localhost:8080

# LLM API endpoint (OpenAI-compatible)
NEXUS_COMMIT_LLM_URL=http://localhost:11434/v1

# LLM model name (e.g., qwen2.5-coder:1.5b)
NEXUS_COMMIT_LLM_MODEL=qwen2.5-coder:1.5b

# LLM API key (any string for local LLM)
NEXUS_COMMIT_LLM_API_KEY=ollama

# Output language (ja or en)
NEXUS_COMMIT_LANG=ja

# Max tokens for prompt context (diff + nexus search results)
NEXUS_COMMIT_MAX_TOKENS=8192

# Timeouts in milliseconds
NEXUS_COMMIT_NEXUS_TIMEOUT_MS=5000
NEXUS_COMMIT_LLM_TIMEOUT_MS=60000
