{
  "name": "@yohi/nexus-commit",
  "version": "1.1.0",
  "description": "AI-powered Conventional Commits generator using local LLM and Nexus index",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "nxc": "./dist/bin/nxc.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yohi/nexus-commit.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc && node -e \"import('node:fs').then(f=>f.chmodSync('dist/bin/nxc.js',0o755))\"",
    "dev": "tsx src/bin/nxc.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "license:check": "license-checker --summary --onlyAllow \"MIT;Apache-2.0;BSD-3-Clause;ISC;0BSD;BSD-2-Clause;Python-2.0;BlueOak-1.0.0;CC0-1.0;MIT*;(MIT AND CC-BY-3.0);CC-BY-3.0\"",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "js-tiktoken": "^1.0.21",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "license-checker": "^25.0.1",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  }
}
