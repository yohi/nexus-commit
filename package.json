{
  "name": "@yohi/nexus-commit",
  "version": "0.1.0",
  "description": "AI-powered Conventional Commits generator using local LLM and Nexus index",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "nxc": "./dist/bin/nxc.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"import('node:fs').then(f=>f.chmodSync('dist/bin/nxc.js',0o755))\"",
    "dev": "tsx src/bin/nxc.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "format": "prettier --write src tests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  }
}
